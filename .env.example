# VEGA 3.0 Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it's in .gitignore.

# === xAI / Grok LLM ===
XAI_API_KEY=your-xai-api-key-here
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4-1-fast-reasoning

# === OpenAI Embeddings ===
OPENAI_API_KEY=your-openai-api-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# === IronClaw ===
IRONCLAW_DB_URL=postgresql://ironclaw:your-password-here@localhost:5432/ironclaw

# === Obsidian Vault Path ===
OBSIDIAN_VAULT_PATH=~/Library/Mobile Documents/com~apple~CloudDocs/Linglepedia

# === Google API (Personal Gmail — Calendar, Gmail, Drive) ===
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# === Microsoft 365 / Azure AD (GIX — Outlook, Calendar, OneDrive/SharePoint) ===
AZURE_CLIENT_ID=your-azure-app-client-id-here
AZURE_CLIENT_SECRET=your-azure-app-client-secret-here
AZURE_TENANT_ID=your-gix-tenant-id-here

# VEGA 3.0 Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it's in .gitignore.

# === xAI / Grok LLM ===
XAI_API_KEY=your-xai-api-key-here
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4.20

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# === IronClaw ===
IRONCLAW_DB_URL=postgresql://ironclaw:your-password-here@localhost:5432/ironclaw

# === Obsidian Vault Path ===
OBSIDIAN_VAULT_PATH=/path/to/your/Linglepedia

# === Google API (for Drive and Calendar) ===
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# === Gmail ===
GMAIL_CLIENT_ID=your-gmail-client-id-here
GMAIL_CLIENT_SECRET=your-gmail-client-secret-here
